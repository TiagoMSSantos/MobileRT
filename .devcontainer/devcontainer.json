{
  "name": "Universal Dev Container",
  "image": "mcr.microsoft.com/devcontainers/universal:5.1.5",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2.5.7": {},
    "ghcr.io/devcontainers/features/git:1.3.5": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2.16.1": {
      "moby": false
    },
    "ghcr.io/nordcominc/devcontainer-features/android-sdk:1.2.0": {},
    "ghcr.io/devcontainers/features/rust:1.5.0": {},
    "ghcr.io/devcontainers/features/java:1.7.2": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpp-devtools",
        "ms-vscode.cpptools-extension-pack",
        "ms-azuretools.vscode-docker",
        "GitHub.copilot-chat",
        "github.vscode-github-actions",
        "mathiasfrohlich.Kotlin",
        "redhat.java",
        "rust-lang.rust-analyzer"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },
  "remoteUser": "vscode",
  "updateContentCommand": "sudo apt-get update -y",
  "postCreateCommand": "echo 'Devcontainer ready!'"
}
